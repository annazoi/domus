generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum Reason {
  BLOCKED
  MAINTENANCE
  BOOKED
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum PropertyBrandingTheme {
  CANVAS
  ARCHITECTURA
  MIZU
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  PENDING
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  first_name String
  last_name  String
  role       UserRole @default(USER)
  vat_number String?
  password   String
  phone        String?
  bio          String?
  avatar_id    String? @unique
  banner_id    String? @unique
  is_verified  Boolean @default(false)
  is_host     Boolean  @default(false)
  is_archived Boolean  @default(true)
  stripe_account_id            String?  @unique
  stripe_onboarding_completed  Boolean  @default(false)
  charges_enabled              Boolean  @default(false)
  payouts_enabled              Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt


  guest_customers Customer[] @relation("CustomerGuestUser")
  host_customers  Customer[] @relation("CustomerHostUser")
  avatar                Document?              @relation("UserAvatar", fields: [avatar_id], references: [id])
  banner                Document?              @relation("UserBanner", fields: [banner_id], references: [id])
  properties            Property[]
  property_images       PropertyImage[]
  property_availability PropertyAvailability[]
  bookings_as_guest     Booking[]              @relation("GuestBookings")
  bookings_as_host      Booking[]              @relation("HostBookings")
  service_orders        ServiceOrder[]
  host_services         Service[]
  documents             Document[]             @relation("UserDocuments")
  host_conversations    Conversation[]         @relation("HostConversations")
  guest_conversations   Conversation[]         @relation("GuestConversations")
  sent_messages         Message[]

  @@map("users")
  @@index([email])
  @@index([id])
}

model Customer {
  id           String   @id @default(uuid())
  guest_user_id String
  host_user_id      String
  first_name   String
  last_name    String
  email        String
  phone        String?
  vat_number   String?
  notes        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  country      String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  guest_user User      @relation("CustomerGuestUser", fields: [guest_user_id], references: [id])
  host       User      @relation("CustomerHostUser", fields: [host_user_id], references: [id], map: "customers_host_id_fkey")
  bookings Booking[]
  service_orders ServiceOrder[]

  @@unique([guest_user_id, host_user_id])
  @@index([guest_user_id])
  @@index([host_user_id], map: "customers_host_id_idx")
  @@index([email])
  @@map("customers")
}


model Property {
  id            String   @id @default(uuid())
  user_id       String
  title         String
  slug          String   @unique
  description   String?
  short_description String?
  location_access   String?
  property_type String
  check_in_time DateTime @default(now())
  check_out_time DateTime @default(now())
  max_guests    Int
  bedrooms      Int
  beds          Int
  bathrooms     Int
  country       String
  city          String
  address       String
  latitude      Float
  longitude     Float
  isPublished   Boolean  @default(false)
  branding_theme PropertyBrandingTheme @default(CANVAS)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  room_type     String

  user         User                   @relation(fields: [user_id], references: [id])
  amenities    PropertyAmenity[]
  availability PropertyAvailability[]
  images       PropertyImage[]
  bookings          Booking[]
  property_services PropertyService[]
  conversations     Conversation[]

  @@index([user_id, isPublished])
  @@map("properties")
}

model Conversation {
  id            String   @id @default(uuid())
  host_user_id  String
  guest_user_id String
  property_id   String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  host     User      @relation("HostConversations", fields: [host_user_id], references: [id])
  guest    User      @relation("GuestConversations", fields: [guest_user_id], references: [id])
  property Property  @relation(fields: [property_id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([host_user_id, guest_user_id, property_id])
  @@index([host_user_id, updated_at])
  @@index([guest_user_id, updated_at])
  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  body            String
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [sender_id], references: [id])

  @@index([conversation_id, created_at])
  @@map("messages")
}

model Booking {
  id           String         @id @default(uuid())
  host_user_id      String
  property_id  String
  guest_user_id     String
  customer_id  String

  check_in     DateTime
  check_out    DateTime
  guests       Int
  total_price  Decimal
  status       BookingStatus  @default(CONFIRMED)
  stripe_session_id   String?  @unique
  payment_intent_id   String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  guest    User     @relation("GuestBookings", fields: [guest_user_id], references: [id])
  customer Customer @relation(fields: [customer_id], references: [id])
  host     User     @relation("HostBookings", fields: [host_user_id], references: [id])
  service_orders ServiceOrder[]

  @@index([property_id])
  @@index([guest_user_id])
  @@index([property_id, check_in, check_out])
  @@map("bookings")
}

model ServiceOrder {
  id          String   @id @default(uuid())
  user_id     String
  service_id  String
  booking_id  String
  customer_id String
  quantity    Int      @default(1)
  unit_price  Decimal
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id])
  service  Service  @relation(fields: [service_id], references: [id])
  booking  Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id])

  @@index([booking_id])
  @@index([service_id])
  @@map("service_orders")
}

model PropertyService {
  id          String   @id @default(uuid())
  property_id String
  service_id  String
  created_at  DateTime @default(now())

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([property_id, service_id])
  @@index([property_id])
  @@index([service_id])
  @@map("property_services")
}

model Service {
  id                 String   @id @default(uuid())
  host_user_id       String
  name               String
  description        String?
  price              Decimal
  quantitable_item   Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  host              User              @relation(fields: [host_user_id], references: [id])
  property_services PropertyService[]
  orders            ServiceOrder[]

  @@index([host_user_id])
  @@map("services")
}

model PropertyAvailability {
  id            String   @id @default(uuid())
  user_id       String
  property_id   String
  date          DateTime
  price         Decimal
  is_available  Boolean  @default(true)
  reason        Reason?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id])

  @@unique([property_id, date])
  @@index([property_id, date])
  @@map("property_availability")
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  property_id String
  selected    Boolean  @default(true)
  quantity    Int?
  value       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  documents   Document[]

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([property_id, value])
  @@index([property_id])
  @@map("property_amenities")
}

model PropertyImage {
  id           String   @id @default(uuid())
  user_id      String
  property_id  String
  document_id  String? @unique
  description  String?
  is_cover     Boolean  @default(false)
  order        Int
  created_at   DateTime @default(now())

  property  Property   @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [user_id], references: [id])
  document Document? @relation(fields: [document_id], references: [id])

  @@map("property_images")
  @@index([property_id, order])
}

model Document {
  id                  String         @id @default(uuid())
  user_id             String
  filename            String
  mimetype            String
  size                Int
  url                 String
  path                String
  type                DocumentType   @default(IMAGE)
  order               Int            @default(0)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  property_amenity_id String?

  user             User             @relation("UserDocuments", fields: [user_id], references: [id])
  property_image   PropertyImage?
  property_amenity PropertyAmenity? @relation(fields: [property_amenity_id], references: [id])
  user_avatar   User?            @relation("UserAvatar")
  user_banner   User?            @relation("UserBanner")

  @@index([user_id])
  @@map("documents")
}
