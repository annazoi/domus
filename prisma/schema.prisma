generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum Reason {
  BLOCKED
  MAINTENANCE
  BOOKED
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  first_name String
  last_name  String
  role       UserRole @default(USER)
  vat_number String?
  password   String
  phone        String?
  bio          String?
  avatar_id    String? @unique
  banner_id    String? @unique
  is_verified  Boolean @default(false)
  is_host     Boolean  @default(true)
  is_archived Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  avatar   Document? @relation("UserAvatar", fields: [avatar_id], references: [id])
  banner   Document? @relation("UserBanner", fields: [banner_id], references: [id])
  properties              Property[]
  property_images         PropertyImage[]
  property_availability   PropertyAvailability[]
  documents               Document[] @relation("UserDocuments")

  @@map("users")
  @@index([email])
  @@index([id])
}

model Property {
  id            String   @id @default(uuid())
  user_id       String
  title         String
  slug          String   @unique
  description   String?
  short_description String?
  property_type String
  check_in_time DateTime @default(now())
  check_out_time DateTime @default(now())
  max_guests    Int
  bedrooms      Int
  beds          Int
  bathrooms     Int
  country       String
  city          String
  address       String
  latitude      Float
  longitude     Float
  isPublished   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  room_type     String

  user         User                   @relation(fields: [user_id], references: [id])
  amenities    PropertyAmenity[]
  availability PropertyAvailability[]
  images       PropertyImage[]

  @@index([user_id, isPublished])
  @@map("properties")
}

model PropertyAvailability {
  id            String   @id @default(uuid())
  user_id       String
  property_id   String
  date          DateTime
  price         Decimal
  is_available  Boolean  @default(true)
  reason        Reason?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id])

  @@unique([property_id, date])
  @@index([property_id, date])
  @@map("property_availability")
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  property_id String
  selected    Boolean  @default(true)
  quantity    Int?
  value       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  documents   Document[]

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([property_id, value])
  @@index([property_id])
  @@map("property_amenities")
}

model PropertyImage {
  id           String   @id @default(uuid())
  user_id      String
  property_id  String
  document_id  String? @unique
  description  String?
  is_cover     Boolean  @default(false)
  order        Int
  created_at   DateTime @default(now())

  property  Property   @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [user_id], references: [id])
  document Document? @relation(fields: [document_id], references: [id])

  @@map("property_images")
  @@index([property_id, order])
}

model Document {
  id                  String         @id @default(uuid())
  user_id             String
  filename            String
  mimetype            String
  size                Int
  url                 String
  path                String
  type                DocumentType   @default(IMAGE)
  order               Int            @default(0)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  property_amenity_id String?

  user             User             @relation("UserDocuments", fields: [user_id], references: [id])
  property_image   PropertyImage?
  property_amenity PropertyAmenity? @relation(fields: [property_amenity_id], references: [id])
  user_avatar   User?            @relation("UserAvatar")
  user_banner   User?            @relation("UserBanner")

  @@index([user_id])
  @@map("documents")
}
